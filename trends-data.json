async function loadTrends() {
  const container = document.getElementById('trends-widget');
  if (!container) return;

  try {
    const res = await fetch('/trends-data.json');
    const json = await res.json();
    const timeline = json.interest_over_time.timeline_data;

    const keywords = ['tech regulation', 'corporate reputation', 'public affairs', 'AI policy', 'data privacy'];
    const colors = ['#b8843a', '#1a1d29', '#5a5d6b', '#888b99', '#c4b49a'];

    const labels = timeline.map(t => {
const parts = t.date.split(/\s*[\u2013\u2014-]\s*/)[0].trim().split(' ');
      return parts[0] + ' ' + parts[1];
    });

    const datasets = keywords.map((kw, i) => ({
      label: kw.charAt(0).toUpperCase() + kw.slice(1),
      data: timeline.map(t => {
        const match = t.values.find(v => v.query.toLowerCase() === kw.toLowerCase());
        return match ? match.extracted_value : 0;
      }),
      borderColor: colors[i],
      backgroundColor: colors[i] + '15',
      borderWidth: i === 0 ? 2.5 : 1.8,
      pointRadius: 0,
      pointHoverRadius: 4,
      tension: 0.4,
      fill: false
    }));

    const canvas = document.createElement('canvas');
    canvas.style.maxHeight = '320px';
    container.appendChild(canvas);

    new Chart(canvas, {
      type: 'line',
      data: { labels, datasets },
      options: {
        responsive: true,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: {
            position: 'bottom',
            labels: {
              font: { family: 'system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif', size: 12 },
              color: '#5a5d6b',
              boxWidth: 16,
              padding: 20,
              usePointStyle: true,
              pointStyle: 'line'
            }
          },
          tooltip: {
            backgroundColor: '#ffffff',
            borderColor: 'rgba(26,29,41,0.08)',
            borderWidth: 1,
            titleColor: '#1a1d29',
            bodyColor: '#5a5d6b',
            padding: 12,
            callbacks: {
              label: ctx => ` ${ctx.dataset.label}: ${ctx.parsed.y}`
            }
          }
        },
        scales: {
          x: {
            ticks: {
              maxTicksLimit: 8,
              font: { family: 'system-ui, sans-serif', size: 11 },
              color: '#888b99'
            },
            grid: { display: false },
            border: { color: 'rgba(26,29,41,0.08)' }
          },
          y: {
            min: 0,
            max: 100,
            ticks: {
              font: { family: 'system-ui, sans-serif', size: 11 },
              color: '#888b99',
              stepSize: 25
            },
            grid: { color: 'rgba(26,29,41,0.06)' },
            border: { display: false },
            title: {
              display: true,
              text: 'Search interest (0–100)',
              font: { size: 11 },
              color: '#888b99'
            }
          }
        }
      }
    });

  } catch (e) {
    container.innerHTML = '<p style="color:#5a5d6b;font-size:14px;">Trend data unavailable.</p>';
    console.error('Trends widget error:', e);
  }
}

document.addEventListener('DOMContentLoaded', loadTrends);
